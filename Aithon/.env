# ─── Aithon Configuration ─────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://aithon:aithon_secret@localhost:5432/aithon_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=aithon-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
 
# File Storage
UPLOAD_DIR=./uploads
SYNTHETIC_OUTPUT_DIR=./synthetic_output
MAX_UPLOAD_SIZE_MB=100

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# SLA
DEFAULT_SLA_SECONDS=300
MAX_CONCURRENT_TASKS=50
OPENAI_API_KEY='AIzaSyAeIutf7fddi6YIBuYiNAWuOqfNrd_apVw'